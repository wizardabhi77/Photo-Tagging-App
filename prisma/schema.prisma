generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Image {
  id Int @id @default(autoincrement())
  source String @unique
  faces FaceCard[]

  @@map("image")
}
model FaceCard {
  id Int @id @default(autoincrement())
  top Int 
  left Int
  size Int @default(100)
  selection String @unique
  image Image @relation(fields: [imageId], references: [id])
  imageId Int 

  @@map("facecard")
}

model ScoreBoard {
  id Int @id @default(autoincrement())
  name String
  seconds Int

  @@map("scoreboard")
}
